# DeepSeek API Key（必填，从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI 兼容 Base URL（可选，默认 https://api.deepseek.com）
OPENAI_BASE_URL=https://api.deepseek.com

# Tavily 搜索 API Key（可选）
TAVILY_API_KEY=

# 嵌入模型（fastembed = 免费本地 ONNX，无需 API key）
EMBEDDING_PROVIDER=fastembed

# TTS 配置
TTS_PROVIDER=edge
VOICE_NAME=zh-CN-XiaoxiaoNeural
SPEAKING_RATE=1.0
PITCH=0.0
VOLUME=1.0

# --- 以下为 Docker 构建时变量 ---
# VITE_API_BASE：前端 API 地址。Docker 部署用 /api（nginx 反向代理）。本地开发用 http://127.0.0.1:8000
VITE_API_BASE=/api
# VITE_WS_BASE：WebSocket 地址。留空 = 从浏览器 location 自动推导（推荐）
VITE_WS_BASE=
